  },
  "keywords": [
    "fishweather",
    "weather",
    "wind",
    "wave",
    "forecast",
    "marine",
    "fishing",
    "mcp",
    "claude",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/volare-consulting-software/fishweather.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "^1.52.0"
  }
}
