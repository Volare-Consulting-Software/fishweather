{
  "name": "@volare-consulting/fishweather-forecast",
  "version": "1.0.4",
  "description": "7-day fishing forecast combining FishWeather wind/wave/weather data, NOAA tide predictions, and moon phases. Available as a CLI, Node.js library, and MCP server for Claude Code.",
  "main": "dist/services/forecastService.js",
  "types": "dist/services/forecastService.d.ts",
  "bin": {
    "fishweather": "dist/main.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "forecast": "tsx src/main.ts",
    "mcp": "tsx src/mcpServer.ts",
    "install-browser": "npx playwright install chromium",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "fishweather",
    "weather",
    "wind",
    "wave",
    "forecast",
    "marine",
    "fishing",
    "tides",
    "noaa",
    "moon-phase",
    "mcp",
    "claude",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/volare-consulting-software/fishweather.git"
  },
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "^1.52.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "moq.ts": "^10.0.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
