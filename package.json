{
  "name": "@volare-consulting/fishweather-forecast",
  "version": "1.0.3",
  "description": "7-day fishing forecast combining FishWeather wind/wave/weather data, NOAA tide predictions, and moon phases. Available as a CLI, Node.js library, and MCP server for Claude Code.",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "fishweather": "dist/forecast.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "forecast": "tsx src/forecast.ts",
    "mcp": "tsx src/mcp-server.ts",
    "install-browser": "npx playwright install chromium"
  },
  "keywords": [
    "fishweather",
    "weather",
    "wind",
    "wave",
    "forecast",
    "marine",
    "fishing",
    "tides",
    "noaa",
    "moon-phase",
    "mcp",
    "claude",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/volare-consulting-software/fishweather.git"
  },
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
